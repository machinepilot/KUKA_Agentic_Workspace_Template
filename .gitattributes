# Git LFS for large binary source material
kuka_dataset/raw_sources/**/*.pdf filter=lfs diff=lfs merge=lfs -text
kuka_dataset/raw_sources/**/*.zip filter=lfs diff=lfs merge=lfs -text
kuka_dataset/raw_sources/**/*.docx filter=lfs diff=lfs merge=lfs -text
kuka_dataset/raw_sources/**/*.pptx filter=lfs diff=lfs merge=lfs -text

# Normalize line endings for text
*.md           text eol=lf
*.mdc          text eol=lf
*.json         text eol=lf
*.py           text eol=lf
*.yaml         text eol=lf
*.yml          text eol=lf
*.toml         text eol=lf

# KRL sources: treat as text with CRLF (KUKA controllers expect CRLF)
*.src          text eol=crlf
*.dat          text eol=crlf
*.sub          text eol=crlf
*.kfd          text eol=crlf

# Exports
*.png          binary
*.jpg          binary
