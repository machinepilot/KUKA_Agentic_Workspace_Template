{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://twa.example/schemas/dataset_manifest.schema.json",
  "title": "DatasetManifest",
  "description": "Machine-readable catalog of normalized dataset entries under kuka_dataset/normalized/.",
  "type": "object",
  "required": ["version", "entries"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "generated_at": { "type": ["string", "null"], "format": "date-time" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path", "topic", "tier", "kuka_platform", "revision_date"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "path": { "type": "string", "description": "Relative to kuka_dataset/normalized/" },
          "topic": { "type": "string" },
          "tier": { "type": "string", "enum": ["T1", "T2", "T3", "T4", "generated"] },
          "kuka_platform": { "type": "array", "items": { "type": "string" } },
          "kss_version": { "type": "array", "items": { "type": "string" } },
          "language": { "type": "string" },
          "revision_date": { "type": "string", "format": "date" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "superseded_by": { "type": ["string", "null"] }
        }
      }
    }
  }
}
